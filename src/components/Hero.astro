---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { meta } from '../data/rules';
import Ball from './Ball.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Decorative balls scattered around the hero edges (kept clear of the centered
// title / tagline / stats column). The last two are hidden on small screens.
const deco = [
  { n: 3, top: '14%', left: '6%', size: 58, delay: '0s' },
  { n: 11, top: '72%', left: '10%', size: 46, delay: '0.6s' },
  { n: 8, top: '20%', left: '87%', size: 64, delay: '0.3s' },
  { n: 6, top: '74%', left: '85%', size: 50, delay: '0.9s' },
  { n: 14, top: '46%', left: '7%', size: 40, delay: '1.2s' },
  { n: 1, top: '50%', left: '90%', size: 38, delay: '0.45s' },
];

const stats = [
  { value: '3', label: t('hero.players') },
  { value: '1', label: t('hero.table') },
  { value: '0', label: t('hero.mercy') },
];
---

<section class="hero">
  <div class="hero-deco no-print" aria-hidden="true">
    {deco.map((d) => (
      <span class="float" style={`top:${d.top};left:${d.left};animation-delay:${d.delay}`}>
        <Ball n={d.n} size={d.size} />
      </span>
    ))}
  </div>

  <div class="wrap hero-inner">
    <p class="eyebrow hero-eyebrow">{t('hero.players')} · {t('hero.table')} · {t('hero.mercy')}</p>
    <h1 class="hero-title">{meta.name}</h1>
    <p class="hero-tagline">{meta.tagline[locale]}</p>

    <div class="hero-cta no-print">
      <a class="btn btn-primary" href="#intro">{t('hero.cta')}</a>
      <a class="btn btn-ghost" href="#cheatsheet">{t('hero.ctaCheatsheet')}</a>
    </div>

    <ul class="hero-stats">
      {stats.map((s) => (
        <li>
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 20% 0%, #1aa06a, transparent 45%),
      radial-gradient(circle at 100% 100%, #0a4d36, transparent 55%),
      linear-gradient(160deg, #0e7a4f, #083b2a);
    color: var(--cream);
    isolation: isolate;
  }
  .hero::after {
    /* subtle felt texture via layered dots */
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1.4px);
    background-size: 14px 14px;
    z-index: -1;
    opacity: 0.6;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-block: clamp(3.5rem, 9vw, 6.5rem);
    text-align: center;
  }
  .hero-eyebrow {
    color: rgba(251, 246, 234, 0.75);
    justify-content: center;
    display: flex;
  }
  .hero-title {
    font-size: clamp(3rem, 1.5rem + 9vw, 6.5rem);
    margin: 0.1em 0 0.15em;
    color: #fff;
    text-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
    letter-spacing: -0.02em;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.1rem, 0.9rem + 1.2vw, 1.6rem);
    color: rgba(251, 246, 234, 0.92);
    max-width: 34rem;
    margin: 0 auto 1.8rem;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-grid;
    grid-auto-flow: column;
    gap: clamp(1.2rem, 5vw, 3.5rem);
  }
  .hero-stats li {
    display: grid;
    gap: 0.15rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 1.4rem + 2.4vw, 3rem);
    color: var(--ball-yellow);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(251, 246, 234, 0.75);
  }

  /* Floating decorative balls */
  .hero-deco {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .float {
    position: absolute;
    animation: bob 5s ease-in-out infinite;
    opacity: 0.9;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-14px) rotate(4deg); }
  }

  @media (max-width: 40rem) {
    /* Fewer distractions on small screens */
    .float:nth-child(n + 5) { display: none; }
  }
</style>
