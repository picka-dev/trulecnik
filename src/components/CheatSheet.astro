---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { cheatsheet } from '../data/rules';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="cheatsheet" class="section cheat">
  <div class="wrap">
    <header class="sec-head">
      <span class="sec-emoji" aria-hidden="true">📋</span>
      <div>
        <h2>{t('cheatsheet.title')}</h2>
        <p class="cheat-sub">{t('cheatsheet.subtitle')}</p>
      </div>
    </header>

    <ul class="cheat-list">
      {cheatsheet.map((item) => (
        <li>
          <span class="dot" aria-hidden="true">●</span>
          <span>{item[locale]}</span>
        </li>
      ))}
    </ul>

    <button class="btn btn-primary no-print" type="button" onclick="window.print()">
      🖨️ {t('print')}
    </button>
  </div>
</section>

<style>
  .cheat { background: var(--cream-2); }
  .sec-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .sec-emoji {
    font-size: clamp(1.8rem, 1.4rem + 1.6vw, 2.6rem);
    line-height: 1;
  }
  .sec-head h2 {
    font-size: clamp(1.7rem, 1.3rem + 1.8vw, 2.4rem);
    margin: 0;
  }
  .cheat-sub {
    margin: 0.2rem 0 0;
    color: var(--ink-soft);
  }

  .cheat-list {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
    counter-reset: cheat;
  }
  @media (min-width: 44rem) {
    .cheat-list { grid-template-columns: 1fr 1fr; }
  }
  .cheat-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.85rem 1.05rem;
    font-weight: 600;
    box-shadow: var(--shadow-soft);
  }
  .dot {
    color: var(--felt);
    font-size: 0.7rem;
    line-height: 1.6;
    flex: none;
  }
</style>
