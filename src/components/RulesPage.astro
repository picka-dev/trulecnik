---
import Base from '../layouts/Base.astro';
import Hero from './Hero.astro';
import RuleSection from './RuleSection.astro';
import CheatSheet from './CheatSheet.astro';
import GroupPicker from './GroupPicker.astro';
import type { Locale } from '../i18n/ui';
import { sections, meta } from '../data/rules';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const title =
  locale === 'cs'
    ? `${meta.name} — pravidla kulečníku pro tři`
    : `${meta.name} — three-player billiards rules`;
const description =
  locale === 'cs'
    ? 'Kompletní pravidla Trulečníku — kulečníku pro tři hráče podle hry cut-throat, s dořešenými spornými situacemi. Včetně taháku k vytištění a losovačky skupin.'
    : 'The complete rules of Trulečník — three-player cut-throat billiards with the argument-starting edge cases resolved. Includes a printable cheat sheet and a group draw.';
---

<Base locale={locale} title={title} description={description}>
  <Hero locale={locale} />
  {sections.map((section) => <RuleSection section={section} locale={locale} />)}
  <GroupPicker locale={locale} />
  <CheatSheet locale={locale} />
</Base>
