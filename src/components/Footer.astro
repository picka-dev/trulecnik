---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { meta } from '../data/rules';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap foot">
    <p class="foot-tag">
      <strong>{meta.name}</strong> — {t('footer.tagline')}
    </p>
    <p class="foot-note no-print">{t('footer.draftNote')}</p>
    <p class="foot-meta">© {year} · {t('footer.madeWith')}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--felt-dark);
    color: rgba(251, 246, 234, 0.86);
    padding-block: 2.5rem;
  }
  .foot { display: grid; gap: 0.6rem; }
  .foot-tag {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 0;
    color: var(--cream);
  }
  .foot-tag strong { color: var(--ball-yellow); }
  .foot-note {
    margin: 0;
    max-width: var(--reading);
    color: rgba(251, 246, 234, 0.7);
    font-size: 0.95rem;
  }
  .foot-meta {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(251, 246, 234, 0.55);
  }
</style>
