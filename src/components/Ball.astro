---
// A single billiard ball rendered as inline SVG, using standard pool colors.
// Solids 1–7 (+ black 8), stripes 9–15. Also renders the white cue ball.
import { ballColor, isStripe as isStripeNum } from '../lib/ball';

interface Props {
  /** Ball number 1–15. Ignored when `cue` is set. */
  n?: number;
  /** Render the white cue ball. */
  cue?: boolean;
  /** Diameter in px. */
  size?: number;
  /** Optional accessible label; defaults to the number / "cue ball". */
  label?: string;
  class?: string;
}

const { n = 1, cue = false, size = 44, label, class: className } = Astro.props;

const isStripe = !cue && isStripeNum(n);
const fill = cue ? 'var(--ball-white)' : ballColor(n);
const numberOnDark = !cue && n === 8;
const numText = cue ? '' : String(n);
const a11y = label ?? (cue ? 'cue ball' : `ball ${n}`);
const uid = `ball-${cue ? 'cue' : n}-${Math.random().toString(36).slice(2, 7)}`;
---

<svg
  class:list={['ball', className]}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  role="img"
  aria-label={a11y}
  style={`--ball-size:${size}px`}
>
  <defs>
    <radialGradient id={`${uid}-shine`} cx="36%" cy="30%" r="75%">
      <stop offset="0%" stop-color="rgba(255,255,255,0.9)" />
      <stop offset="22%" stop-color="rgba(255,255,255,0.28)" />
      <stop offset="55%" stop-color="rgba(255,255,255,0)" />
      <stop offset="100%" stop-color="rgba(0,0,0,0.22)" />
    </radialGradient>
    <clipPath id={`${uid}-clip`}>
      <circle cx="50" cy="50" r="48" />
    </clipPath>
  </defs>

  <!-- base -->
  <circle cx="50" cy="50" r="48" fill={isStripe ? 'var(--ball-white)' : fill} />

  {isStripe && (
    <g clip-path={`url(#${uid}-clip)`}>
      <rect x="0" y="27" width="100" height="46" fill={fill} />
    </g>
  )}

  <!-- number chip -->
  {!cue && (
    <>
      <circle cx="50" cy="50" r="21" fill="var(--ball-white)" />
      <text
        x="50"
        y="50"
        text-anchor="middle"
        dominant-baseline="central"
        font-family="'Baloo 2', system-ui, sans-serif"
        font-weight="700"
        font-size="26"
        fill={numberOnDark ? 'var(--ball-black)' : '#1c1c1c'}
      >{numText}</text>
    </>
  )}

  <!-- gloss overlay -->
  <circle cx="50" cy="50" r="48" fill={`url(#${uid}-shine)`} />
  <circle cx="50" cy="50" r="48" fill="none" stroke="rgba(0,0,0,0.12)" stroke-width="1" />
</svg>

<style>
  .ball {
    display: inline-block;
    vertical-align: middle;
    filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.22));
    flex: none;
  }
</style>
