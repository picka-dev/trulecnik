---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/ui';
import { alternateLocalePath, localizedPath } from '../i18n/utils';
import { locales, defaultLocale } from '../i18n/ui';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const site = Astro.site ?? new URL('https://trulecnik.cz');

const ogImage = new URL(`/og/og-${locale}.png`, site).href;
const ogImageAlt =
  locale === 'cs'
    ? 'Trulečník — kulečník pro tři hráče'
    : 'Trulečník — billiards for three players';

const canonicalPath = localizedPath(
  Astro.url.pathname.replace(new RegExp(`^/(${locales.join('|')})(/|$)`), '/'),
  locale,
);
const canonical = new URL(canonicalPath, site).href;

// hreflang alternates for every locale.
const alternates = locales.map((l) => ({
  locale: l,
  href: new URL(alternateLocalePath(Astro.url, l), site).href,
}));

// Structured data: the site itself plus the game it documents.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${site.href}#website`,
      url: site.href,
      name: 'Trulečník',
      description,
      inLanguage: locale,
    },
    {
      '@type': 'Game',
      '@id': `${site.href}#game`,
      name: 'Trulečník',
      alternateName: locale === 'cs' ? 'Cut-throat kulečník' : 'Cut-throat billiards',
      url: canonical,
      description,
      inLanguage: locale,
      numberOfPlayers: {
        '@type': 'QuantitativeValue',
        value: 3,
      },
      mainEntityOfPage: canonical,
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.locale} href={a.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(alternateLocalePath(Astro.url, defaultLocale), site).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Trulečník" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'cs' ? 'cs_CZ' : 'en_US'} />
    <meta
      property="og:locale:alternate"
      content={locale === 'cs' ? 'en_US' : 'cs_CZ'}
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0c5e40" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link no-print" href="#main">
      {locale === 'cs' ? 'Přeskočit na obsah' : 'Skip to content'}
    </a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--gold);
        color: #3a2400;
        padding: 0.6rem 1rem;
        border-radius: 0 0 var(--radius-sm) var(--radius-sm);
        font-family: var(--font-display);
        font-weight: 600;
        z-index: 100;
      }
      .skip-link:focus {
        left: 1rem;
      }
    </style>
  </body>
</html>
